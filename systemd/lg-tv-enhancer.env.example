# Template for /etc/default/lg-tv-enhancer (root-owned, chmod 600, out of git).
#   sudo cp lg-tv-enhancer.env.example /etc/default/lg-tv-enhancer
#   sudo chmod 600 /etc/default/lg-tv-enhancer

# LG TV's LAN IP (give the TV a DHCP reservation so it can't drift).
LGTV_HOST=192.168.1.50

# webOS pairing key. Reuse tv-dsp's key (same TV, same client library):
#   grep TVDSP_TV_KEY /etc/default/tv-dsp
# or, after a fresh interactive pairing:
#   sqlite3 ~/.aiopylgtv.sqlite 'select value from unnamed'
LGTV_KEY=

# Location for sunset/sunrise. Rough coordinates are fine — a whole degree of
# error moves the transitions by only a few minutes.
LGTV_LAT=40.7128
LGTV_LON=-74.0060

# How often to retry while the TV is unreachable / a write is pending (seconds).
#LGTV_POLL_SECS=60

# Optional circadian color temperature ramp (f.lux-style). Enable by setting
# LGTV_CT_NIGHT; -50 (warm) .. 50 (cool). See README.
#LGTV_CT_NIGHT=-30
#LGTV_CT_DAY=0
#LGTV_CT_RAMP_MINS=45
