# Template for /etc/default/lg-tv-enhancer (root-owned, chmod 600, out of git).
#   sudo cp lg-tv-enhancer.env.example /etc/default/lg-tv-enhancer
#   sudo chmod 600 /etc/default/lg-tv-enhancer

# LG TV's hostname or LAN IP. Prefer a DNS name that tracks the TV's DHCP
# lease (e.g. LGwebOSTV.home) — it survives IP changes and interface moves
# (wired <-> Wi-Fi). If only an IP works, give the TV a DHCP reservation so
# it can't drift.
LGTV_HOST=LGwebOSTV.home

# webOS pairing key. Reuse tv-dsp's key (same TV, same client library):
#   grep TVDSP_TV_KEY /etc/default/tv-dsp
# or, after a fresh interactive pairing:
#   sqlite3 ~/.aiopylgtv.sqlite 'select value from unnamed'
LGTV_KEY=

# Location for sunset/sunrise. Rough coordinates are fine — a whole degree of
# error moves the transitions by only a few minutes.
LGTV_LAT=40.7128
LGTV_LON=-74.0060

# How often to retry while the TV is unreachable / a write is pending (seconds).
#LGTV_POLL_SECS=60

# --- ISF preset keeper (lg-tv-preset.service) ---------------------------------
# Presets are recognized by their picture-settings fingerprint
# "contrast,backlight,brightness" (the C9 won't report pictureMode by name).
# The C9 stores picture settings PER INPUT, so a preset can read different
# values on different inputs (e.g. an HDMI/cable input vs. the built-in apps).
# List every fingerprint for a preset, ';'-separated. Re-derive with:
#   /home/pi/lg-tv-enhancer/venv/bin/python src/preset_daemon.py --listen
# Turn OFF Energy Saving / OLED-Light auto-dimming first, or backlight drifts
# and the fingerprint won't hold still (also better for calibrated ISF modes).
#LGTV_PRESET_BRIGHT=90,90,65;90,100,60
#LGTV_PRESET_DARK=85,10,50;85,28,50

# pictureMode value written to restore each preset.
#LGTV_MODE_BRIGHT=expert1
#LGTV_MODE_DARK=expert2

# Seconds after an app/input change to still attribute a mode change to it.
#LGTV_SETTLE_SECS=3
